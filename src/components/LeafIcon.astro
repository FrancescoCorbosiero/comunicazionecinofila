---
// Unico ornamento del brand: foglia line-art (mai ramoscelli affollati).
interface Props {
  size?: number;
  stroke?: string;
  class?: string;
}
const { size = 40, stroke = 'var(--peach)', class: className } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  class={className}
  aria-hidden="true"
>
  <path
    d="M16 28 C16 16, 22 8, 28 5 C26 14, 22 22, 16 28 Z M16 28 C16 16, 10 8, 4 5 C6 14, 10 22, 16 28 Z M16 28 L16 6"
    stroke={stroke}
    stroke-width="1.4"
    stroke-linejoin="round"
    fill="none"
  ></path>
</svg>
