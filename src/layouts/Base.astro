---
import '../styles/brand.css';
import '../styles/site.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CallModal from '../components/CallModal.astro';
import { SITE, SITE_NAME, EMAIL, PHONE, IG_URL } from '../config';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  active?: string;
  /** Structured data aggiuntivi (Article, Event…) da unire al grafo base. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  ogImage = '/assets/logo-original.jpg',
  ogType = 'website',
  active,
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE).href;
const ogImageAbs = new URL(ogImage, SITE).href;

const baseGraph: Record<string, unknown>[] = [
  {
    '@type': 'Person',
    '@id': `${SITE}/#andrea`,
    name: 'Andrea Bellettati',
    jobTitle: 'Consulente in comportamento e nutrizione per cani e gatti',
    url: SITE,
    image: `${SITE}/assets/logo-original.jpg`,
    sameAs: [IG_URL],
  },
  {
    '@type': 'LocalBusiness',
    '@id': `${SITE}/#business`,
    name: SITE_NAME,
    description:
      'Consulenza in comportamento e alimentazione naturale per cani e gatti. Partner Reico Italia.',
    image: `${SITE}/assets/logo-original.jpg`,
    url: SITE,
    email: EMAIL,
    telephone: PHONE,
    areaServed: 'IT',
    priceRange: 'Consulenza gratuita',
    founder: { '@id': `${SITE}/#andrea` },
    sameAs: [IG_URL],
    knowsAbout: [
      'Alimentazione naturale per cani e gatti',
      'Comportamento animale',
      'Lettura delle etichette del pet food',
      'Benessere di cani e gatti',
    ],
  },
];

const extra = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [...baseGraph, ...extra],
};

const fontHref =
  'https://fonts.googleapis.com/css2?family=Anton&family=Playfair+Display:ital,wght@0,500;0,600;1,500;1,600&family=Inter:wght@400;500;600;700&family=Caveat:wght@600;700&family=Cormorant+Garamond:ital,wght@1,500;1,600&family=JetBrains+Mono:wght@400&display=swap';
---
<!doctype html>
<html lang="it" data-titlestyle="poster" data-paper="on">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/jpeg" href="/assets/logo-original.jpg" />
    <link rel="apple-touch-icon" href="/assets/logo-original.jpg" />
    <meta name="theme-color" content="#7c9474" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:site_name" content={SITE_NAME} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- Google Fonts: Anton, Inter, Caveat, Playfair Display, Cormorant Garamond, JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontHref} rel="stylesheet" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    <slot name="head" />
  </head>
  <body class="brand paper-bg">
    <SiteHeader active={active} />
    <main>
      <slot />
    </main>
    <SiteFooter />
    <CallModal />
    <script>
      import '../scripts/site.ts';
    </script>
  </body>
</html>
