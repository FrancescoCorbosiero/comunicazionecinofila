---
import Base from '../layouts/Base.astro';
import LeafIcon from '../components/LeafIcon.astro';
import ArrowIcon from '../components/ArrowIcon.astro';
import CoverImage from '../components/CoverImage.astro';
import andrea1 from '../assets/andrea-1.jpg';
import andrea2 from '../assets/andrea-2.jpg';
import { LANDING_MODE } from '../config';

if (LANDING_MODE) return Astro.redirect('/');
---
<Base
  active="approccio"
  ogType="article"
  title="Approccio — Andrea Bellettati · Comportamento & Nutrizione"
  description="Il mio approccio: comportamento e alimentazione insieme. Osservazione, letteratura scientifica e contesto reale. La storia di Andrea Bellettati e del suo bassotto."
  ogTitle="L'approccio — Andrea Bellettati"
  ogDescription="Non vendo crocchette. Costruisco equilibrio: comportamento e alimentazione, sempre insieme."
  ogImage="/assets/andrea-1.jpg"
>
  <!-- PAGE HERO -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split-body" data-reveal>
          <span class="eyebrow kicker-rule">Chi sono · L'approccio</span>
          <h1 class="display-lg">
            Non vendo<br />crocchette.<br /><span style="color:var(--peach-deep);"
              >Costruisco<br />equilibrio.</span
            >
          </h1>
          <p class="lead">
            Mi chiamo Andrea Bellettati e sono un esperto in comportamento e nutrizione per cani e
            gatti. Studio da anni la relazione che intercorre tra questi due mondi: non si può
            parlare di benessere animale senza tenerli insieme.
          </p>
          <a class="btn btn-lg" href="/contatti">
            Prenota la consulenza gratuita <ArrowIcon size={16} />
          </a>
        </div>
        <div class="split-media parallax-cover" data-reveal data-delay="1" style="aspect-ratio:4/5;">
          <CoverImage
            src={andrea1}
            alt="Andrea Bellettati seduto su una roccia con il suo bassotto, lungo un fiume di montagna"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="section bg-deep paper-bg-deep">
    <div class="container">
      <div class="head-block" data-reveal>
        <span class="eyebrow kicker-rule">Il manifesto</span>
        <h2 class="display-lg">Tre principi<br />che non negozio.</h2>
      </div>
      <div class="principi" data-reveal data-delay="1">
        <div class="principio">
          <span class="pno">01</span>
          <h3>Cibo e comportamento<br />sono la stessa storia</h3>
          <p>
            Un cane irrequieto, un gatto che si gratta, una digestione difficile: spesso la risposta
            è nella ciotola tanto quanto nelle abitudini. Li guardo insieme, mai separati.
          </p>
        </div>
        <div class="principio">
          <span class="pno">02</span>
          <h3>La scienza prima<br />delle mode</h3>
          <p>
            Niente slogan, niente “grain free” perché fa tendenza. Parto dalla letteratura, leggo le
            etichette riga per riga e spiego il perché di ogni scelta.
          </p>
        </div>
        <div class="principio">
          <span class="pno">03</span>
          <h3>Il piano deve entrare<br />nella vita vera</h3>
          <p>
            La dieta perfetta sulla carta non serve a niente se la famiglia non riesce a seguirla.
            Costruisco qualcosa di sostenibile, per l'animale e per chi se ne prende cura.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BIO -->
  <section class="section">
    <div class="container">
      <div class="split flip">
        <div class="split-media parallax-cover" data-reveal style="aspect-ratio:4/5;">
          <CoverImage
            src={andrea2}
            alt="Andrea Bellettati guancia a guancia con il suo bassotto, in inverno"
          />
        </div>
        <div class="split-body" data-reveal data-delay="1">
          <span class="eyebrow kicker-rule">Vivo con un bassotto</span>
          <h2 class="display-md">La teoria la verifico<br />ogni giorno, a casa.</h2>
          <p>
            Convivo con un bassotto: ogni cosa che studio passa prima dalla nostra quotidianità. Le
            passeggiate, i pasti, le piccole intolleranze, gli inverni in montagna. È lì che la
            nutrizione smette di essere una tabella e diventa cura concreta.
          </p>
          <p>
            Questo è anche il modo in cui lavoro con te: con la pazienza e l'onestà di chi sa che
            dall'altra parte c'è un compagno di vita, non un “caso”.
          </p>
          <blockquote style="border-left:3px solid var(--peach); padding-left:18px; margin:6px 0 0;">
            <p style="font-family:var(--serif); font-style:italic; font-size:20px; color:var(--olive-deep);">
              «Alimentare correttamente il proprio amico a quattro zampe è, insieme alla sua
              educazione, la più grande forma di amore.»
            </p>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- PULL QUOTE -->
  <section class="section bg-sage paper-bg" style="background-color:var(--sage);">
    <div class="container">
      <div class="pullquote" data-reveal>
        <span class="section-mark" aria-hidden="true">
          <LeafIcon size={38} stroke="var(--cream-ink)" />
        </span>
        <q>
          Se l'alimentazione è sbagliata la medicina è inutile; se l'alimentazione è corretta la
          medicina non è necessaria.
        </q>
        <cite>Proverbio ayurvedico · il cuore del mio lavoro</cite>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <!-- NOTE: date/tappe da confermare con Andrea — struttura pronta, testi modificabili -->
  <section class="section">
    <div class="container container-narrow">
      <div class="head-block" data-reveal>
        <span class="eyebrow kicker-rule">Il percorso</span>
        <h2 class="display-lg">Da una passione<br />a un metodo.</h2>
      </div>
      <div class="timeline" data-reveal data-delay="1">
        <div class="tl-item">
          <div class="tl-year">L'inizio</div>
          <h4>Dalla convivenza allo studio</h4>
          <p>
            La curiosità per ciò che metto nella ciotola del mio cane diventa studio serio:
            etichette, ingredienti, letteratura scientifica. Capisco quanto poco se ne parli
            davvero.
          </p>
        </div>
        <div class="tl-item">
          <div class="tl-year">2021</div>
          <h4>Entro in un team multidisciplinare</h4>
          <p>
            Mi unisco a un gruppo di professionisti nato per portare consapevolezza su un argomento
            troppo spesso sottovalutato. Formazione continua, confronto e metodo condiviso.
          </p>
        </div>
        <div class="tl-item">
          <div class="tl-year">Oggi</div>
          <h4>Consulenze e divulgazione</h4>
          <p>
            Consulenze 1:1 per famiglie, collaborazione con Reico, webinar e contenuti come
            “Etichette a 4 Zampe” e l'antistaminico naturale. Sempre con lo stesso obiettivo: scelte
            consapevoli.
          </p>
        </div>
        <div class="tl-item is-now">
          <div class="tl-year">Con te</div>
          <h4>Il prossimo passo</h4>
          <p>
            Una consulenza gratuita di 45 minuti per analizzare alimentazione e comportamento del
            tuo animale, e un piano di lavoro firmato su misura.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-tight bg-deep paper-bg-deep">
    <div class="container container-narrow">
      <div class="cta-band">
        <h2 class="display-md">Raccontami il tuo animale.</h2>
        <p class="lead">Il primo passo è gratuito e senza impegno.</p>
        <div class="cta-row">
          <a class="btn btn-lg" href="/contatti">Consulenza gratuita</a>
          <a class="btn btn-ghost-cream btn-lg" href="/servizi">Vedi i servizi</a>
        </div>
      </div>
    </div>
  </section>
</Base>
