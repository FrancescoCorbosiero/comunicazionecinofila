---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import EventRow from '../components/EventRow.astro';
import ArrowIcon from '../components/ArrowIcon.astro';
import WhatsAppIcon from '../components/WhatsAppIcon.astro';
import { waLink, IG_URL, SITE } from '../config';
import { eventDay, eventMonthTime } from '../lib/dates';

const all = await getCollection('eventi');
const featured = all.find((e) => e.data.featured) ?? all[0];
const statusOrder: Record<string, number> = { upcoming: 0, 'on-request': 1, past: 2, 'coming-soon': 3 };
const rest = all
  .filter((e) => e.id !== featured?.id)
  .sort(
    (a, b) =>
      statusOrder[a.data.status] - statusOrder[b.data.status] ||
      (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
  );

const f = featured?.data;
const reserve = f?.reserveWaText
  ? waLink(f.reserveWaText)
  : waLink('Ciao Andrea! Vorrei riservare il mio posto al prossimo webinar.');

const eventLd = f
  ? {
      '@type': 'Event',
      name: f.title,
      description: f.excerpt,
      ...(f.date ? { startDate: f.date.toISOString() } : {}),
      eventAttendanceMode: 'https://schema.org/OnlineEventAttendanceMode',
      eventStatus: 'https://schema.org/EventScheduled',
      location: { '@type': 'VirtualLocation', url: IG_URL },
      ...(f.cover ? { image: new URL(f.cover, SITE).href } : {}),
      isAccessibleForFree: f.free,
      organizer: { '@type': 'Person', name: 'Andrea Bellettati' },
    }
  : undefined;
---
<Base
  active="eventi"
  title="Eventi & Webinar — Andrea Bellettati"
  description="Webinar e incontri live su alimentazione e benessere di cani e gatti. Etichette a 4 Zampe: impara a leggere le etichette e a scegliere con consapevolezza."
  ogTitle="Eventi & Webinar — Andrea Bellettati"
  ogDescription="Etichette a 4 Zampe e altri incontri live, gratuiti e a posti limitati."
  ogImage="/assets/feed-etichette.jpg"
  jsonLd={eventLd}
>
  <!-- INTRO -->
  <section class="section-tight">
    <div class="container">
      <div class="head-block" data-reveal style="max-width:760px;">
        <span class="eyebrow kicker-rule">Eventi &amp; Webinar</span>
        <h1 class="display-xl">
          Impariamo<br />insieme, <span
            class="script"
            style="font-family:var(--script); font-size:0.6em; text-transform:none;">live</span
          >.
        </h1>
        <p class="lead">
          Incontri online gratuiti per fare chiarezza su alimentazione e benessere. Si parla di
          etichette, ingredienti, scelte quotidiane — con spazio per le tue domande.
        </p>
      </div>
    </div>
  </section>

  <!-- FEATURED EVENT -->
  {
    featured && f && (
      <section class="section-tight">
        <div class="container">
          <div class="event-feature" data-reveal>
            <div class="event-feature-media parallax-cover">
              {f.statusLabel && (
                <span class="event-status">
                  <span class="pill pill-peach">{f.statusLabel}</span>
                </span>
              )}
              {f.cover ? (
                <img src={f.cover} alt={f.coverAlt ?? f.title} loading="lazy" decoding="async" data-parallax data-parallax-cover />
              ) : (
                <div class="placeholder" style="position:absolute; inset:0;">
                  {f.placeholderLabel ?? 'EVENTO'}
                </div>
              )}
            </div>
            <div class="event-feature-body">
              {f.date && (
                <div class="event-date">
                  <span class="d">{eventDay(f.date)}</span>
                  <span class="m">{eventMonthTime(f.date)}</span>
                </div>
              )}
              <h2 class="display-md">{f.title}</h2>
              {f.subtitle && (
                <p style="font-weight:600; color:var(--olive-deep); font-size:18px; margin:0;">
                  {f.subtitle}
                </p>
              )}
              <p>{f.excerpt}</p>
              {f.tags.length > 0 && (
                <div class="svc-tag-row">
                  {f.tags.map((t) => (
                    <span class="pill">{t}</span>
                  ))}
                </div>
              )}
              <div class="event-meta-row">
                {f.locationLabel && (
                  <span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path
                        d="M15 10l4.5-2.5v9L15 14M3 7h12v10H3z"
                        stroke="currentColor"
                        stroke-width="1.6"
                        stroke-linejoin="round"
                      />
                    </svg>
                    {f.locationLabel}
                  </span>
                )}
                {f.duration && (
                  <span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6" />
                      <path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                    </svg>
                    Durata {f.duration}
                  </span>
                )}
                {f.free && (
                  <span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path
                        d="M12 21s-7-4.5-7-10a7 7 0 0114 0c0 5.5-7 10-7 10z"
                        stroke="currentColor"
                        stroke-width="1.6"
                        stroke-linejoin="round"
                      />
                      <circle cx="12" cy="11" r="2.4" stroke="currentColor" stroke-width="1.6" />
                    </svg>
                    Evento gratuito
                  </span>
                )}
              </div>
              <div class="hero-cta-row" style="margin-top:6px;">
                <a class="btn btn-lg" href={reserve} target="_blank" rel="noopener">
                  Riserva il tuo posto <WhatsAppIcon size={16} />
                </a>
                <a class="btn btn-ghost btn-lg" href={`/eventi/${featured.id}`}>
                  Tutti i dettagli <ArrowIcon size={16} />
                </a>
              </div>
              {f.collab && (
                <p class="field-hint" style="margin-top:2px;">
                  In collaborazione con {f.collab}.
                </p>
              )}
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- AGENDA -->
  {
    rest.length > 0 && (
      <section class="section-tight">
        <div class="container">
          <div class="head-block" data-reveal>
            <span class="eyebrow kicker-rule">In programma &amp; in replay</span>
            <h2 class="display-md">Altri appuntamenti</h2>
          </div>
          <div class="event-list" data-reveal data-delay="1">
            {rest.map((entry) => (
              <EventRow entry={entry} />
            ))}
          </div>
          <p class="field-hint" style="margin-top:16px;">
            I nuovi eventi vengono annunciati prima su Instagram. Vuoi essere avvisato?{' '}
            <a class="text-link" href="/contatti">
              Scrivimi
            </a>
            .
          </p>
        </div>
      </section>
    )
  }

  <!-- CTA -->
  <section class="section-tight bg-deep paper-bg-deep">
    <div class="container container-narrow">
      <div class="cta-band">
        <h2 class="display-md">Preferisci un confronto<br />tutto tuo?</h2>
        <p class="lead">La consulenza 1:1 parte da un primo incontro gratuito di 45 minuti.</p>
        <div class="cta-row">
          <a class="btn btn-lg" href="/contatti">Consulenza gratuita</a>
        </div>
      </div>
    </div>
  </section>
</Base>
